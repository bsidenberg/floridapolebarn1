# Email (Resend — get your key at resend.com, it's free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where quote leads get emailed
CONTACT_EMAIL=info@floridapolebarn.com

# Your site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://floridapolebarn.com

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Marketing bot lead ingestion (server-side only — never expose to browser)
# Must match the value set in the fpb-marketing-bot Vercel project
# Used as x-leads-ingest-secret header when POSTing to https://fpb-marketing-bot.vercel.app/api/leads
LEADS_INGEST_SECRET=your_marketing_bot_ingest_secret_here
